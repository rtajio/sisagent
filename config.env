# Configuración de la aplicación SISAGENT
SECRET_KEY=tu-clave-secreta-muy-segura-aqui

# DATABASE_URL DESACTIVADA para desarrollo local: la app usará SQLite automáticamente.
# Esta variable es solo para producción (Railway la inyecta con PostgreSQL).
# NUNCA debe apuntar a MySQL/pymysql en local — pymysql no está instalado y rompe el reloader de Flask.
# DATABASE_URL=mysql+pymysql://usuario:password@localhost/sisagent

# Configuración de la base de datos MySQL (NO USAR — referencia antigua)
# Reemplaza con tus credenciales reales
# DATABASE_URL=mysql+pymysql://root:tu_password@localhost/sisagent